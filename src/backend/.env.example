# =============================================================================
# Archivo:      .env.example
# Descripción:  Plantilla de variables de entorno para el backend de auth.
#               Copiar este archivo como ".env" y completar con valores
#               REALES antes de correr el backend. El archivo ".env" real
#               NUNCA se versiona (ver .gitignore).
# Autor:        Francisco Bevilacqua | Versión: 1.0.0
#
# =============================================================================

# -----------------------------------------------------------------------------
# JWT — Firma y verificación de tokens
# -----------------------------------------------------------------------------
# [SEC] Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# Mínimo 32 bytes de entropía. NUNCA reusar un secreto de ejemplo en producción.
JWT_SECRET_KEY=GENERAR_CON_secrets.token_hex_32_NO_USAR_ESTE_VALOR
JWT_ALGORITHM=HS256

# Duración del token en minutos. 60 min es razonable para una sesión de
# operación del brazo robótico (ver ADR-02 en planificacion.md).
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Usuarios habilitados — formato: username:hash_bcrypt separados por coma
# -----------------------------------------------------------------------------
# [SEC] Las contraseñas NUNCA van en texto plano, ni siquiera acá.
# Generar el hash con el script scripts/generar_hash_password.py incluido
# en este paquete, y pegar el resultado completo (incluye el prefijo $2b$).
#
# Formato: AUTH_USERS=usuario1:$2b$12$hash...,usuario2:$2b$12$hash...
AUTH_USERS=francisco:GENERAR_HASH_AQUI,evaluador:GENERAR_HASH_AQUI

# -----------------------------------------------------------------------------
# CORS — orígenes permitidos para llamar a este backend desde el navegador
# -----------------------------------------------------------------------------
# [SEC] En desarrollo local con la GUI abierta como archivo (file://) o
# servida por un servidor estático simple, ajustar al origen real.
# NUNCA usar "*" en un despliegue real — acá se acepta como simplificación
# de demo en LAN de confianza (documentado en README como trabajo futuro).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000

# True en desarrollo (logs detallados, /docs habilitado).
# [SEC] Poner en False ante cualquier despliegue fuera de tu PC de demo.
DEBUG_MODE=True
